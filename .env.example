# GreenScan — Environment-Vorlage
# Kopiere diese Datei nach .env (nicht committen!) und fülle die Werte aus.
# .env wird von scripts/ gelesen.

# ─── Supabase ──────────────────────────────────────────────────────────
# Project-Ref aus index.html: vowbiueikwrauuceilhc
SUPABASE_PROJECT_REF=vowbiueikwrauuceilhc

# Service-Role-Key (Settings → API → service_role secret).
# WIRD NICHT als Edge-Function-Secret gesetzt — Supabase liefert ihn
# automatisch via SUPABASE_SERVICE_ROLE_KEY in jeder Edge Function.
# Aber: scripts/50-cron.sh braucht ihn, um in vault.secrets zu schreiben.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SERVICEROLE...

# Optional: Database-URL falls direkter psql-Zugriff statt CLI gewünscht.
# Format: postgres://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# ─── Anthropic (Claude) ───────────────────────────────────────────────
# Erstellt auf https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Stripe (für Webhook + optional Auto-Webhook-Setup) ───────────────
# Live-Keys aus https://dashboard.stripe.com/apikeys (für Test: test-Modus-Keys)
STRIPE_SECRET_KEY=sk_live_XXXXX
# Webhook-Signing-Secret. Wird in scripts/60-stripe-webhook.sh
# automatisch erzeugt, wenn leer (mit Stripe-API).
STRIPE_WEBHOOK_SECRET=
# Falls du den Webhook manuell anlegst: Endpoint-URL hier, sonst leer:
STRIPE_WEBHOOK_ENDPOINT=

# ─── VAPID (Web Push) ─────────────────────────────────────────────────
# scripts/30-secrets.sh generiert sie automatisch wenn leer
# (via `npx web-push generate-vapid-keys`).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@greenscan.ch

# ─── iNaturalist (optional) ──────────────────────────────────────────
# Erstellt auf https://www.inaturalist.org/oauth/applications/new
# Redirect URI MUSS sein: https://greenscan.ch/
GS_INAT_CLIENT_ID=

# ─── Cloudflare Pages (optional, falls du via API/CLI deployen willst) ─
# Standard: Cloudflare baut automatisch nach git push origin main.
# Token braucht es nur, wenn der Agent den Build manuell triggern soll.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=greenscan

# ─── Deployment-Verhalten ────────────────────────────────────────────
# Wenn 1: scripts/deploy.sh führt jeden Schritt mit Bestätigung aus.
# Wenn 0: vollautomatisch (für CI/CD/Agent).
GS_INTERACTIVE=0

# Wenn 1: Schritte werden nur "geplant" gezeigt, nicht ausgeführt (dry-run).
GS_DRY_RUN=0
