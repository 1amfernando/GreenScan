# GreenScan — Cloudflare Pages Security Headers (v24.50)
# Apply to every path on the deployed site.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(self), microphone=(), geolocation=(self), payment=(self), accelerometer=(), gyroscope=(), magnetometer=(), usb=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-origin
  X-DNS-Prefetch-Control: on
  # Frame-ancestors (CSP-only equivalent of X-Frame-Options) — keep both for older UA support.
  Content-Security-Policy: default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob: data:; connect-src 'self' https://*.supabase.co https://api.anthropic.com https://*.nvidia.com https://api.stripe.com https://js.stripe.com https://*.openstreetmap.org https://nominatim.openstreetmap.org https://api.open-meteo.com https://geocoding-api.open-meteo.com https://*.tile.openstreetmap.org https://en.wikipedia.org https://ipapi.co https://www.google.com wss://*.supabase.co; frame-src https://js.stripe.com https://hooks.stripe.com https://checkout.stripe.com; worker-src 'self' blob:; manifest-src 'self'; base-uri 'self'; form-action 'self' https://checkout.stripe.com; frame-ancestors 'self'; upgrade-insecure-requests

# Service-Worker scope: keep same-origin and let it self-update aggressively.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# Manifest
/manifest.json
  Cache-Control: public, max-age=300
  Content-Type: application/manifest+json; charset=utf-8

# Static icons / splash — long cache, content-hashed by name.
/icons/*
  Cache-Control: public, max-age=31536000, immutable

# Offline fallback page
/offline.html
  Cache-Control: public, max-age=600
